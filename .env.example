# ================================
# EHTMS - Environment Configuration
# Copy to .env and fill in values
# ================================

# Application
APP_NAME=EHTMS
APP_ENV=development  # development, staging, production
API_V1_PREFIX=/api/v1

# Database (Docker service name: postgres)
DATABASE_URL=postgresql://ehtms_user:ehtms_pass@postgres:5432/ehtms_db

# Security - CHANGE IN PRODUCTION
SECRET_KEY=dev-secret-key-change-in-production-please-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS - Comma-separated origins (no spaces)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8501","http://127.0.0.1:8000"]

# File Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# MinIO/S3 Storage (Optional - fallback to local FS if not set)
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minio_admin
# MINIO_SECRET_KEY=minio_password_123
# MINIO_BUCKET=ehtms-uploads
# MINIO_USE_PRESIGNED_URLS=true

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Streamlit Frontend (if deployed separately)
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0